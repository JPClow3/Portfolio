---
import ThemeToggle from '@components/islands/ThemeToggle.svelte';
import Icon from '@components/common/Icon.astro';
import { defaultLang, type Lang, ui } from '@/lib/i18n';

interface NavLink {
  label: string;
  href: string;
  section: string;
}

const currentLang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = ui[currentLang] ?? ui[defaultLang];

const isEnglish = currentLang === 'en';
const isPortuguese = currentLang === 'pt';

const navLinks: NavLink[] = [
  { label: t['nav.about'], href: '/#about', section: 'about' },
  { label: t['nav.projects'], href: '/#projects', section: 'projects' },
  { label: t['nav.experience'], href: '/#experience', section: 'experience' },
  { label: t['nav.activity'], href: '/#activity', section: 'activity' },
  { label: t['nav.blog'], href: '/blog', section: 'blog' },
  { label: t['nav.contact'], href: '/#contact', section: 'contact' },
];

// Resume link (separate since it has download behavior)
const resumeLink = isPortuguese ? '/resume-pt.pdf' : '/resume-en.pdf';

---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 glass border-b border-[rgb(var(--color-border)/0.55)] transition-shadow duration-300"
>
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-14 items-center justify-between">
      <!-- Logo -->
      <a
        href="/"
        id="site-logo"
        data-logo-signal
        class="header-logo text-lg font-bold gradient-text transition-opacity hover:opacity-85 focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg-primary))]"
        aria-label="Joao Paulo home"
      >
        JP<span class="text-[rgb(var(--color-text-secondary))]">.</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            data-nav-link
            data-nav-section={link.section}
            class="nav-link relative rounded-md px-3 py-1.5 text-sm font-medium text-[rgb(var(--color-text-secondary))] transition-colors hover:text-[rgb(var(--color-text-primary))] focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg-primary))] group"
          >
            {link.label}
            <span class="absolute bottom-0 left-1/2 h-px w-0 -translate-x-1/2 bg-[rgb(var(--color-accent))] transition-all duration-300 group-hover:w-4/5" />
          </a>
        ))}
      </div>

      <!-- Right Section -->
      <div class="flex items-center gap-2">
        <a
          href={resumeLink}
          download
          class="hidden items-center gap-1.5 rounded-md bg-[rgb(var(--color-accent))] px-3 py-1.5 text-sm font-semibold text-[rgb(var(--color-accent-contrast))] shadow-sm transition hover:bg-[rgb(var(--color-accent-hover))] md:inline-flex"
          aria-label={`${t['nav.resume']} PDF`}
        >
          <Icon name="download" size={16} />
          {t['nav.resume']}
        </a>

        <!-- Language Switcher (Desktop) -->
        <div class="hidden items-center gap-0.5 rounded-md border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-secondary)/0.58)] p-0.5 md:flex" role="group" aria-label="Select language">
          <a
            href="/"
            data-lang-link
            data-lang-base="/"
            class:list={[
              'rounded px-2.5 py-1 text-xs font-semibold transition-colors',
              isEnglish
                ? 'bg-[rgb(var(--color-accent))] text-[rgb(var(--color-accent-contrast))]'
                : 'text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text-primary))]',
            ]}
            aria-label="Switch to English"
            aria-current={isEnglish ? 'true' : undefined}
          >EN</a>
          <a
            href="/pt/"
            data-lang-link
            data-lang-base="/pt/"
            class:list={[
              'rounded px-2.5 py-1 text-xs font-semibold transition-colors',
              isPortuguese
                ? 'bg-[rgb(var(--color-accent))] text-[rgb(var(--color-accent-contrast))]'
                : 'text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text-primary))]',
            ]}
            aria-label="Mudar para Português"
            aria-current={isPortuguese ? 'true' : undefined}
          >PT</a>
        </div>

        <ThemeToggle client:load />

        <!-- Mobile Menu Button -->
        <button
          type="button"
          class="rounded-md p-2 transition-colors hover:bg-[rgb(var(--color-bg-secondary))] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg-primary))] md:hidden"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          id="mobile-menu-button"
        >
          <!-- Hamburger icon -->
          <span id="menu-icon-open" aria-hidden="true" class="flex items-center justify-center">
            <Icon name="menu" size={24} />
          </span>
          <!-- Close icon (hidden by default) -->
          <span id="menu-icon-close" aria-hidden="true" class="hidden flex items-center justify-center">
            <Icon name="close" size={24} />
          </span>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div
      id="mobile-menu"
      role="navigation"
      aria-label="Mobile navigation"
      class="overflow-hidden rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-primary))] shadow-[0_18px_50px_rgb(var(--glass-shadow)/0.14)] transition-all duration-300 ease-in-out md:hidden"
      style="max-height: 0; opacity: 0;"
    >
      <div class="mt-2 border-t border-[rgb(var(--color-border))] p-2 pt-3">
        <div class="flex flex-col gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              data-nav-link
              data-nav-section={link.section}
              class="nav-link link-underline rounded-md px-4 py-2.5 text-sm font-medium text-[rgb(var(--color-text-secondary))] transition-colors hover:bg-[rgb(var(--color-bg-secondary))] hover:text-[rgb(var(--color-text-primary))] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg-primary))]"
            >
              {link.label}
            </a>
          ))}
          <a
            href={resumeLink}
            download
            class="flex items-center gap-2 rounded-md px-4 py-2.5 text-sm font-medium text-[rgb(var(--color-accent))] transition-colors hover:bg-[rgb(var(--color-accent)/0.1)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg-primary))]"
          >
            <Icon name="download" size={16} />
            {t['nav.resume']}
          </a>

          <!-- Language Switcher (Mobile) -->
          <div class="mt-1 flex items-center gap-2 border-t border-[rgb(var(--color-border))] px-4 py-2.5 pt-3" role="group" aria-label="Select language">
            <Icon name="globe" size={16} class="text-[rgb(var(--color-text-muted))]" />
            <a
              href="/"
              data-lang-link
              data-lang-base="/"
              class:list={[
                'rounded px-3 py-1.5 text-xs font-semibold transition-colors',
                isEnglish
                  ? 'bg-[rgb(var(--color-accent))] text-[rgb(var(--color-accent-contrast))]'
                  : 'text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text-primary))] bg-[rgb(var(--color-bg-secondary))]',
              ]}
              aria-label="Switch to English"
              aria-current={isEnglish ? 'true' : undefined}
            >EN</a>
            <a
              href="/pt/"
              data-lang-link
              data-lang-base="/pt/"
              class:list={[
                'rounded px-3 py-1.5 text-xs font-semibold transition-colors',
                isPortuguese
                  ? 'bg-[rgb(var(--color-accent))] text-[rgb(var(--color-accent-contrast))]'
                  : 'text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text-primary))] bg-[rgb(var(--color-bg-secondary))]',
              ]}
              aria-label="Mudar para Português"
              aria-current={isPortuguese ? 'true' : undefined}
            >PT</a>
          </div>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  // Global listener references for cleanup
  let globalEscapeHandler: ((e: KeyboardEvent) => void) | null = null;
  let globalClickHandler: ((e: MouseEvent) => void) | null = null;
  let globalResizeHandler: (() => void) | null = null;
  let activeNavObserver: IntersectionObserver | null = null;
  let activeNavScrollHandler: (() => void) | null = null;

  function initMobileMenu() {
    const menuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    if (!menuButton || !mobileMenu) return;

    const menuButtonEl = menuButton;
    const mobileMenuEl = mobileMenu;

    // Guard against re-initialization
    if (menuButtonEl.dataset.initialized === 'true') return;
    menuButtonEl.dataset.initialized = 'true';

    let isOpen = false;
    let focusTrapActive = false;
    let focusTrapHandler: ((e: KeyboardEvent) => void) | null = null;

    function toggleMenu(open?: boolean) {
      isOpen = open !== undefined ? open : !isOpen;

      // Update aria-expanded
      menuButtonEl.setAttribute('aria-expanded', String(isOpen));

      // Toggle icons
      if (iconOpen && iconClose) {
        iconOpen.classList.toggle('hidden', isOpen);
        iconClose.classList.toggle('hidden', !isOpen);
      }

      // Animate menu
      if (isOpen) {
        mobileMenuEl.style.maxHeight = `${mobileMenuEl.scrollHeight}px`;
        mobileMenuEl.style.opacity = '1';
        focusTrapActive = true;
        attachFocusTrap();

        const firstMenuItem = mobileMenuEl.querySelector('a, button, [tabindex]:not([tabindex="-1"])');
        if (firstMenuItem instanceof HTMLElement) {
          window.requestAnimationFrame(() => firstMenuItem.focus());
        }
      } else {
        mobileMenuEl.style.maxHeight = '0';
        mobileMenuEl.style.opacity = '0';
        focusTrapActive = false;
        detachFocusTrap();
        menuButtonEl.focus();
      }
    }

    function closeMenu() {
      toggleMenu(false);
    }

    function attachFocusTrap() {
      const focusableElements = Array.from(
        mobileMenuEl.querySelectorAll('a, button, [tabindex]:not([tabindex="-1"])')
      ) as HTMLElement[];
      
      if (focusableElements.length === 0) return;

      const firstElement = focusableElements[0];
      const lastElement = focusableElements[focusableElements.length - 1];

      // Remove old handler if it exists
      if (focusTrapHandler) {
        mobileMenuEl.removeEventListener('keydown', focusTrapHandler);
      }

      // Create new handler
      focusTrapHandler = (e: KeyboardEvent) => {
        if (!focusTrapActive || e.key !== 'Tab') return;

        if (e.shiftKey && document.activeElement === firstElement) {
          e.preventDefault();
          lastElement.focus();
        } else if (!e.shiftKey && document.activeElement === lastElement) {
          e.preventDefault();
          firstElement.focus();
        }
      };

      mobileMenuEl.addEventListener('keydown', focusTrapHandler);
    }

    function detachFocusTrap() {
      if (focusTrapHandler) {
        mobileMenuEl.removeEventListener('keydown', focusTrapHandler);
        focusTrapHandler = null;
      }
    }

    // Toggle on button click
    menuButtonEl.addEventListener('click', () => toggleMenu());

    // Close menu when clicking a link
    const links = mobileMenuEl.querySelectorAll('a');
    links.forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Set up global listeners only once
    attachGlobalListeners(closeMenu);
  }

  function attachGlobalListeners(closeMenu: () => void) {
    const menuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    if (!menuButton || !mobileMenu) return;

    // Remove old handlers if they exist (from previous initialization)
    if (globalEscapeHandler) {
      document.removeEventListener('keydown', globalEscapeHandler);
    }
    if (globalClickHandler) {
      document.removeEventListener('click', globalClickHandler);
    }
    if (globalResizeHandler) {
      window.removeEventListener('resize', globalResizeHandler);
    }

    // Create and attach new handlers
    globalEscapeHandler = (e: KeyboardEvent) => {
      const currentIsOpen = menuButton.getAttribute('aria-expanded') === 'true';
      if (e.key === 'Escape' && currentIsOpen) {
        closeMenu();
      }
    };

    globalClickHandler = (e: MouseEvent) => {
      const currentIsOpen = menuButton.getAttribute('aria-expanded') === 'true';
      const target = e.target as Node;
      if (currentIsOpen && !menuButton.contains(target) && !mobileMenu.contains(target)) {
        closeMenu();
      }
    };

    globalResizeHandler = () => {
      const currentIsOpen = menuButton.getAttribute('aria-expanded') === 'true';
      if (window.innerWidth >= 768 && currentIsOpen) {
        closeMenu();
      }
    };

    document.addEventListener('keydown', globalEscapeHandler);
    document.addEventListener('click', globalClickHandler);
    window.addEventListener('resize', globalResizeHandler);
  }

  // Header scroll effect with guard
  function initHeaderScroll() {
    const header = document.getElementById('header');
    if (!header || header.dataset.scrollInitialized === 'true') return;
    const headerEl = header;
    headerEl.dataset.scrollInitialized = 'true';

    function handleScroll() {
      if (window.scrollY > 50) {
        headerEl.classList.add('scrolled');
      } else {
        headerEl.classList.remove('scrolled');
      }
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll(); // Check initial state
  }

  function initLangLinks() {
    const hash = window.location.hash;
    const pathname = window.location.pathname;
    
    const isPt = pathname.startsWith('/pt/') || pathname === '/pt';
    let canonicalPath = isPt ? pathname.replace(/^\/pt/, '') : pathname;
    if (!canonicalPath.startsWith('/')) {
      canonicalPath = '/' + canonicalPath;
    }
    const cleanCanonical = canonicalPath === '/' ? '' : canonicalPath.slice(1);
    
    document.querySelectorAll<HTMLAnchorElement>('[data-lang-link]').forEach((link) => {
      const base = link.dataset.langBase;
      if (base) {
        link.href = base + cleanCanonical + hash;
        link.addEventListener('click', () => {
          localStorage.setItem('languagePreference', base === '/pt/' ? 'pt' : 'en');
        });
      }
    });
  }

  function dispatchSceneSection(section: string) {
    window.dispatchEvent(new CustomEvent('portfolio:section-change', {
      detail: { section },
    }));
  }

  function setActiveNav(section: string) {
    document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]').forEach((link) => {
      const isActive = link.dataset.navSection === section;
      link.dataset.active = String(isActive);

      if (isActive) {
        link.setAttribute('aria-current', 'location');
      } else {
        link.removeAttribute('aria-current');
      }
    });

    dispatchSceneSection(section);
  }

  function getRouteSection() {
    const path = window.location.pathname;

    if (path.startsWith('/blog')) return 'blog';
    if (path.startsWith('/projects')) return 'projects';

    return '';
  }

  function getHomepageSections() {
    return ['about', 'projects', 'experience', 'activity', 'contact']
      .map((id) => document.getElementById(id))
      .filter((section): section is HTMLElement => Boolean(section));
  }

  function findCurrentHomepageSection(sections: HTMLElement[]) {
    const anchorY = window.innerHeight * 0.38;
    let bestSection = sections[0]?.id ?? 'about';
    let bestDistance = Number.POSITIVE_INFINITY;

    sections.forEach((section) => {
      const rect = section.getBoundingClientRect();
      const crossesAnchor = rect.top <= anchorY && rect.bottom >= anchorY;
      const distance = crossesAnchor ? 0 : Math.min(Math.abs(rect.top - anchorY), Math.abs(rect.bottom - anchorY));

      if (distance < bestDistance) {
        bestDistance = distance;
        bestSection = section.id;
      }
    });

    return bestSection;
  }

  function initActiveNav() {
    if (activeNavObserver) {
      activeNavObserver.disconnect();
      activeNavObserver = null;
    }

    if (activeNavScrollHandler) {
      window.removeEventListener('scroll', activeNavScrollHandler);
      window.removeEventListener('resize', activeNavScrollHandler);
      activeNavScrollHandler = null;
    }

    const routeSection = getRouteSection();

    if (routeSection) {
      setActiveNav(routeSection);
      return;
    }

    const sections = getHomepageSections();
    if (sections.length === 0) {
      setActiveNav('about');
      return;
    }

    let currentSection = '';
    const syncActiveSection = () => {
      const nextSection = findCurrentHomepageSection(sections);

      if (nextSection !== currentSection) {
        currentSection = nextSection;
        setActiveNav(nextSection);
      }
    };

    activeNavScrollHandler = syncActiveSection;

    if ('IntersectionObserver' in window) {
      activeNavObserver = new IntersectionObserver(syncActiveSection, {
        rootMargin: '-28% 0px -58% 0px',
        threshold: [0, 0.1, 0.35, 0.7],
      });

      sections.forEach((section) => activeNavObserver?.observe(section));
    }

    window.addEventListener('scroll', syncActiveSection, { passive: true });
    window.addEventListener('resize', syncActiveSection);
    syncActiveSection();
  }

  function initLogoSignal() {
    const logo = document.querySelector<HTMLElement>('[data-logo-signal]');
    if (!logo || logo.dataset.logoInitialized === 'true') return;

    logo.dataset.logoInitialized = 'true';
    const emit = (active: boolean) => {
      window.dispatchEvent(new CustomEvent('portfolio:logo-focus', {
        detail: { active },
      }));
    };

    logo.addEventListener('pointerenter', () => emit(true), { passive: true });
    logo.addEventListener('pointerleave', () => emit(false), { passive: true });
    logo.addEventListener('focus', () => emit(true));
    logo.addEventListener('blur', () => emit(false));
  }

  // Initialize on load
  initMobileMenu();
  initHeaderScroll();
  initLangLinks();
  initActiveNav();
  initLogoSignal();
  window.addEventListener('hashchange', initLangLinks);

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', () => {
    // Only re-initialize header scroll (listeners are already attached globally)
    initHeaderScroll();
    initLangLinks();
    initActiveNav();
    initLogoSignal();
  });
</script>

<style>
  #header.scrolled {
    box-shadow: 0 8px 24px rgb(var(--glass-shadow) / 0.08);
  }

  :global(html.dark) #header.scrolled {
    box-shadow: 0 10px 28px rgb(var(--glass-shadow) / 0.24);
  }

  @media (prefers-reduced-motion: reduce) {
    #header {
      transition: none;
    }
  }
</style>
