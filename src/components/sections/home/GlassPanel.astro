---
interface Props {
  class?: string;
  as?: keyof HTMLElementTagNameMap;
}

const { class: className = '', as: Tag = 'div' } = Astro.props;
---

<Tag
  class={`rounded-2xl border border-[rgb(var(--glass-tint)/var(--glass-border-opacity))] bg-[rgb(var(--glass-tint)/var(--glass-bg-opacity))] backdrop-blur-xl shadow-xl shadow-[rgb(var(--glass-shadow)/0.1)] dark:shadow-[rgb(var(--glass-shadow)/0.2)] ${className}`}
>
  <slot />
</Tag>
