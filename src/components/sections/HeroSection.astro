---
import Icon from '@/components/common/Icon.astro';
import { defaultLang, type Lang, ui } from '@/lib/i18n';
import { getCollection } from 'astro:content';
import { getGithubProfile } from '@/lib/github';

const currentLang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = ui[currentLang] ?? ui[defaultLang];

const profileEntries = await getCollection('profile', ({ data }) => data.lang === currentLang);
const fallbackProfileEntries = await getCollection('profile', ({ data }) => data.lang === defaultLang);
const profileEntry = profileEntries[0] ?? fallbackProfileEntries[0];

const profile = profileEntry.data.profile;
const currentFocus = profileEntry.data.currentFocus;

async function getLocalizedCollection(collection: 'projects' | 'experience') {
  const localizedEntries = await getCollection(collection, ({ data }) => data.lang === currentLang);
  if (localizedEntries.length > 0 || currentLang === defaultLang) {
    return localizedEntries;
  }
  return getCollection(collection, ({ data }) => data.lang === defaultLang);
}

const projects = await getLocalizedCollection('projects');
const experience = await getLocalizedCollection('experience');

const githubProfile = await getGithubProfile(profileEntry.data.customMetric.githubUsername);

const currentFocusIconNames = {
  'book-open': 'book-open',
  headphones: 'headphones',
} as const;

const getCurrentFocusIcon = (name: string) =>
  currentFocusIconNames[name as keyof typeof currentFocusIconNames] ?? 'code';

const gravatarUrl = `https://2.gravatar.com/avatar/${profile.gravatarHash}?s=212&d=initials`;
---

<section id="about" data-scene-section="about" aria-labelledby="about-heading" class="relative isolate mb-16 grid min-h-[520px] grid-cols-1 items-center gap-8 overflow-hidden rounded-xl border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-bg-primary)/0.44)] px-5 py-10 sm:px-7 lg:grid-cols-12 lg:px-9">
  <!-- Dynamic radial gradient backdrop -->
  <div class="pointer-events-none absolute -inset-px -z-10 bg-linear-to-b from-[rgb(var(--color-accent)/0.04)] to-transparent dark:from-[rgb(var(--color-accent)/0.08)]"></div>
  <div class="pointer-events-none absolute -top-40 -right-40 -z-10 h-96 w-96 rounded-full bg-[rgb(var(--color-accent))] opacity-10 blur-[100px] dark:opacity-20"></div>
  <div class="pointer-events-none absolute -bottom-40 -left-40 -z-10 h-96 w-96 rounded-full bg-[rgb(var(--color-accent))] opacity-10 blur-[100px] dark:opacity-20"></div>
  
  <div class="relative z-10 lg:col-span-7">
    <h1 id="about-heading" class="max-w-3xl text-4xl font-extrabold leading-[1.03] tracking-tight text-[rgb(var(--color-text-primary))] sm:text-5xl lg:text-6xl animate-fade-in opacity-0 [animation-fill-mode:forwards]">
      {t['home.hero.lead']}
      <span class="text-gradient block">{t['home.hero.highlight']}</span>
      {t['home.hero.tail']}
    </h1>

    <p class="mt-5 max-w-2xl text-base leading-relaxed text-[rgb(var(--color-text-secondary))] sm:text-lg animate-slide-up stagger-1 opacity-0 [animation-fill-mode:forwards]">{profile.subtitle}</p>

    <div class="mt-7 flex flex-wrap gap-3 animate-slide-up stagger-2 opacity-0 [animation-fill-mode:forwards]">
      <a href="#projects" class="hover-lift rounded-md bg-[rgb(var(--color-accent))] px-5 py-2.5 text-sm font-semibold text-[rgb(var(--color-accent-contrast))] transition-colors hover:bg-[rgb(var(--color-accent-hover))]">{t['home.viewWork']}</a>
      <a href={profile.github} target="_blank" rel="noreferrer" class="hover-lift rounded-md border border-[rgb(var(--color-border))] bg-[rgb(var(--glass-tint)/0.28)] px-5 py-2.5 text-sm font-semibold text-[rgb(var(--color-text-primary))] transition-all hover:border-[rgb(var(--color-border-hover))] hover:bg-[rgb(var(--color-bg-tertiary)/0.55)]">{t['home.githubProfile']}</a>
    </div>
  </div>

  <div class="relative z-10 flex flex-col gap-4 lg:col-span-5">
    <article class="hover-3d profile-identity-card rounded-lg text-center" aria-label={`${profile.shortName} profile summary`}>
      <div class="hover-3d-content glass-panel profile-identity-surface rounded-lg p-5">
        <div class="profile-card-topline">
          <span>{t['profile.status']}</span>
          <span aria-hidden="true">JP</span>
        </div>

        <div class="profile-avatar-wrap">
          <div class="profile-avatar-ring">
            <img
              src={gravatarUrl}
              alt={`${profile.shortName}, ${profile.role}`}
              width="212"
              height="212"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="profile-avatar"
            />
          </div>
        </div>

        <h2 class="mt-4 text-2xl font-bold text-[rgb(var(--color-text-primary))]">{profile.shortName}</h2>
        <p class="mt-1 text-sm font-semibold text-[rgb(var(--color-accent))]">{profile.role}</p>

        <div class="mt-4 flex flex-wrap justify-center gap-2 text-xs">
          <span class="profile-chip">BR {profile.location}</span>
          <span class="profile-chip">{profile.timezone}</span>
        </div>

        <div class="mt-5 grid grid-cols-2 gap-2 border-t border-[rgb(var(--color-border)/0.72)] pt-4 text-center">
          <div class="profile-stat"><p>{githubProfile?.publicRepos ?? projects.length}</p><span>{t['home.repos']}</span></div>
          <div class="profile-stat"><p>{experience.length}</p><span>{t['home.roles']}</span></div>
        </div>
      </div>

      <span class="hover-3d-zone" aria-hidden="true"></span>
      <span class="hover-3d-zone" aria-hidden="true"></span>
      <span class="hover-3d-zone" aria-hidden="true"></span>
      <span class="hover-3d-zone" aria-hidden="true"></span>
      <span class="hover-3d-zone" aria-hidden="true"></span>
      <span class="hover-3d-zone" aria-hidden="true"></span>
      <span class="hover-3d-zone" aria-hidden="true"></span>
      <span class="hover-3d-zone" aria-hidden="true"></span>
    </article>

    <article class="glass-panel rounded-lg p-5">
      <p class="mb-3 text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-text-muted))]">{currentFocus.title || t['home.currentFocus']}</p>
      <div class="space-y-3">
        {currentFocus.items.map((item: { icon: string; label: string; value: string }) => (
          <div class="flex items-start gap-3">
            <span class="flex items-center justify-center rounded-md bg-[rgb(var(--color-bg-tertiary))] p-2 text-[rgb(var(--color-accent))]" aria-hidden="true"><Icon name={getCurrentFocusIcon(item.icon)} size={20} /></span>
            <div>
              <p class="text-[10px] uppercase tracking-[0.18em] text-[rgb(var(--color-text-muted))]">{item.label}</p>
              <p class="text-sm text-[rgb(var(--color-text-primary))]">{item.value}</p>
            </div>
          </div>
        ))}
      </div>
    </article>
  </div>
</section>
