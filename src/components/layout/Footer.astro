---
import Icon from '@/components/common/Icon.astro';
import { defaultLang, type Lang, ui } from '@/lib/i18n';

const currentLang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = ui[currentLang] ?? ui[defaultLang];
const currentYear = new Date().getFullYear();

const navLinks = [
  { name: t['nav.about'], href: '/#about' },
  { name: t['nav.projects'], href: '/#projects' },
  { name: t['nav.blog'], href: '/blog' },
  { name: t['nav.contact'], href: '/#contact' },
];

const socialLinks = [
  {
    name: 'GitHub',
    href: 'https://github.com/JPClow3',
    icon: 'github' as const,
  },
  {
    name: 'LinkedIn',
    href: 'https://www.linkedin.com/in/joaopaulosantosgo/',
    icon: 'linkedin' as const,
  },
  {
    name: 'Instagram',
    href: 'https://www.instagram.com/_joao.paulo_sa/',
    icon: 'instagram' as const,
  },
  {
    name: 'Gravatar',
    href: 'https://gravatar.com/jpclow',
    icon: 'external-link' as const,
  },
  {
    name: 'Email',
    href: 'mailto:joaopaulo.grv4@gmail.com',
    icon: 'email' as const,
  },
];
---

<footer class="border-t border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-secondary)/0.72)]">
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <!-- Main Footer Content -->
    <div class="mb-7 grid gap-7 md:grid-cols-3">
      <!-- Logo & About -->
      <div>
        <a href="/" class="text-xl font-bold gradient-text">JP</a>
        <p class="mt-3 text-sm leading-relaxed text-[rgb(var(--color-text-secondary))]">
          {t['footer.aboutText']}
        </p>
      </div>

      <!-- Navigation Links -->
      <div>
        <h3 class="mb-3 font-semibold text-[rgb(var(--color-text-primary))]">{t['footer.quickLinks']}</h3>
        <nav aria-label="Footer navigation" class="grid grid-cols-2 gap-2">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-accent))] transition-colors"
            >
              {link.name}
            </a>
          ))}
        </nav>
      </div>

      <!-- Social & Contact -->
      <div>
        <h3 class="mb-3 font-semibold text-[rgb(var(--color-text-primary))]">{t['footer.connect']}</h3>
        <nav aria-label="Social connections" class="flex items-center gap-3">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="rounded-md bg-[rgb(var(--color-bg-tertiary))] p-2.5 text-[rgb(var(--color-text-secondary))] transition-colors hover:bg-[rgb(var(--color-accent)/0.1)] hover:text-[rgb(var(--color-accent))]"
              aria-label={link.name}
            >
              <Icon name={link.icon} size={20} />
            </a>
          ))}
        </nav>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-[rgb(var(--color-border))] pt-7">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <!-- Copyright -->
        <p class="text-sm text-[rgb(var(--color-text-muted))]">
          &copy; {currentYear} João Paulo Gonçalves Santos. {t['footer.rights']}
        </p>

        <!-- Back to Top -->
        <a
          href="#"
          class="group inline-flex items-center gap-2 text-sm text-[rgb(var(--color-text-secondary))] transition-colors hover:text-[rgb(var(--color-accent))]"
          aria-label={t['common.backToTop']}
        >
          {t['common.backToTop']}
          <Icon name="arrow-down" size={16} class="rotate-180 transition-transform group-hover:-translate-y-0.5" />
        </a>
      </div>

      <!-- Tech Stack -->
      <p class="mt-5 text-center text-sm text-[rgb(var(--color-text-muted))]">
        {t['footer.builtWith']}
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[rgb(var(--color-accent))] hover:underline"
        >
          Astro
        </a>,
        <a
          href="https://svelte.dev"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[rgb(var(--color-accent))] hover:underline"
        >
          Svelte
        </a>
        &amp;
        <a
          href="https://tailwindcss.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[rgb(var(--color-accent))] hover:underline"
        >
          Tailwind CSS
        </a>
      </p>
    </div>
  </div>
</footer>
