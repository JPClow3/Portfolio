---
import { getCollection, type CollectionEntry } from 'astro:content';
import ProjectCaseStudy from '@/components/pages/ProjectCaseStudy.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => data.caseStudy && data.lang === 'pt');
  return projects.map((project) => ({ params: { slug: project.data.slug }, props: { project } }));
}

interface Props { project: CollectionEntry<'projects'>; }
const { project } = Astro.props;
---

<ProjectCaseStudy {project} />
