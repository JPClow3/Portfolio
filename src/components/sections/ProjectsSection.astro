---
import { getCollection } from 'astro:content';
import EmptyState from '@/components/common/EmptyState.astro';
import { defaultLang, type Lang, ui } from '@/lib/i18n';
import ScrollReveal from '@/components/common/ScrollReveal.astro';

const currentLang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = ui[currentLang] ?? ui[defaultLang];

const profileEntries = await getCollection('profile', ({ data }) => data.lang === currentLang);
const fallbackProfileEntries = await getCollection('profile', ({ data }) => data.lang === defaultLang);
const profileEntry = profileEntries[0] ?? fallbackProfileEntries[0];
const profile = profileEntry.data.profile;

async function getLocalizedCollection(collection: 'projects') {
  const localizedEntries = await getCollection(collection, ({ data }) => data.lang === currentLang);
  if (localizedEntries.length > 0 || currentLang === defaultLang) {
    return localizedEntries;
  }
  return getCollection(collection, ({ data }) => data.lang === defaultLang);
}

const projects = (await getLocalizedCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const getProjectSlug = (project: any) =>
  project.id.replace(/\.(md|mdx)$/i, '').replace(/\\/g, '/');

const getProjectUrl = (project: any) =>
  project.data.caseStudy ? `/projects/${getProjectSlug(project)}/` : project.data.link ?? project.data.github ?? '/#projects';
---

<section id="projects" data-scene-section="projects" aria-labelledby="projects-heading" class="mb-16">
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <h2 id="projects-heading" class="text-3xl font-bold tracking-tight">{t['home.buildTitle']}</h2>
    <a href={`${profile.github}?tab=repositories`} target="_blank" rel="noreferrer" class="text-sm text-[rgb(var(--color-text-muted))] transition-colors hover:text-[rgb(var(--color-text-primary))]">{t['home.seeAllRepos']}</a>
  </div>

  <div class="bento-grid">
    {projects.length > 0 ? projects.map((project, index) => {
      const projectUrl = getProjectUrl(project);
      const isExternalProjectUrl = projectUrl.startsWith('http');
      const primaryLabel = project.data.caseStudy ? t['home.caseStudy'] : t['home.viewProject'];

      return (
        <ScrollReveal animation="fade-up" delay={index * 100} tag="div" class:list={[
          'h-full',
          index === 0 ? 'bento-span-2' : '',
          index === 1 ? 'bento-row-span-2' : '',
        ]}>
          <article
            data-tilt-card
            data-testid="project-card"
            class="project-card group glass-panel relative overflow-hidden rounded-lg p-5 transition-all hover:border-[rgb(var(--color-accent))]/40 h-full"
          >
          <div class="absolute inset-0 bg-linear-to-br from-[rgb(var(--color-accent)/0.12)] via-transparent to-[rgb(var(--color-accent-hover)/0.12)] opacity-60 transition-opacity duration-500 group-hover:opacity-100"></div>
          <div class="relative z-10">
            <div class="mb-2 flex items-center justify-between gap-3">
              <h3 class="text-xl font-bold">{project.data.title}</h3>
              {project.data.caseStudy && (
                <span class="shrink-0 rounded-md border border-[rgb(var(--color-accent)/0.32)] bg-[rgb(var(--color-accent)/0.1)] px-2 py-0.5 text-[10px] font-bold uppercase tracking-[0.16em] text-[rgb(var(--color-accent))]">
                  {t['projects.story']}
                </span>
              )}
            </div>
            <p class="text-sm leading-relaxed text-[rgb(var(--color-text-secondary))]">{project.data.description}</p>

            {project.data.caseStudy && (
              <dl class="mt-4 grid gap-3">
                {project.data.problem && (
                  <div class="story-row border-l-2 border-[rgb(var(--color-border)/0.5)] pl-3 transition-colors group-hover:border-[rgb(var(--color-accent)/0.5)]">
                    <dt class="text-[10px] font-bold uppercase tracking-[0.16em] text-[rgb(var(--color-text-muted))]">{t['home.problem']}</dt>
                    <dd class="story-snippet mt-1 text-xs leading-relaxed text-[rgb(var(--color-text-secondary))]">{project.data.problem}</dd>
                  </div>
                )}
                {project.data.solution && (
                  <div class="story-row border-l-2 border-[rgb(var(--color-border)/0.5)] pl-3 transition-colors group-hover:border-[rgb(var(--color-accent)/0.5)]">
                    <dt class="text-[10px] font-bold uppercase tracking-[0.16em] text-[rgb(var(--color-text-muted))]">{t['home.build']}</dt>
                    <dd class="story-snippet mt-1 text-xs leading-relaxed text-[rgb(var(--color-text-secondary))]">{project.data.solution}</dd>
                  </div>
                )}
                {project.data.impact && (
                  <div class="story-row border-l-2 border-[rgb(var(--color-border)/0.5)] pl-3 transition-colors group-hover:border-[rgb(var(--color-accent)/0.5)]">
                    <dt class="text-[10px] font-bold uppercase tracking-[0.16em] text-[rgb(var(--color-text-muted))]">{t['home.result']}</dt>
                    <dd class="story-snippet mt-1 text-xs leading-relaxed text-[rgb(var(--color-text-secondary))]">{project.data.impact}</dd>
                  </div>
                )}
              </dl>
            )}

            <div class="mt-4 flex flex-wrap gap-1.5">
              {project.data.tech.slice(0, 4).map((tech: string) => (
                <span class="rounded-md border border-[rgb(var(--color-border)/0.6)] bg-[rgb(var(--color-bg-secondary)/0.5)] px-2.5 py-1 text-[10px] uppercase tracking-wide text-[rgb(var(--color-text-secondary))] backdrop-blur-md">{tech}</span>
              ))}
            </div>
            <div class="mt-4 flex flex-wrap gap-4 text-sm">
              <a
                href={projectUrl}
                target={isExternalProjectUrl ? '_blank' : undefined}
                rel={isExternalProjectUrl ? 'noreferrer' : undefined}
                class="font-semibold text-[rgb(var(--color-accent))] hover:underline"
                aria-label={`${primaryLabel} - ${project.data.title}`}
              >
                {primaryLabel}
              </a>
              {project.data.caseStudy && project.data.github && (
                <a href={project.data.github} target="_blank" rel="noreferrer" class="text-[rgb(var(--color-text-secondary))] transition-colors hover:text-[rgb(var(--color-text-primary))]" aria-label={`View code for ${project.data.title} on GitHub`}>{t['home.code']}</a>
              )}
              {project.data.link && <a href={project.data.link} target="_blank" rel="noreferrer" class="text-[rgb(var(--color-text-secondary))] transition-colors hover:text-[rgb(var(--color-text-primary))]" aria-label={`View live site for ${project.data.title}`}>{t['home.live']}</a>}
            </div>
          </div>
        </article>
        </ScrollReveal>
      );
    }) : (
      <div class="col-span-full">
        <EmptyState 
          iconName="code" 
          title={t['projects.emptyTitle']} 
          description={t['projects.emptyDesc']} 
        />
      </div>
    )}
  </div>
</section>
