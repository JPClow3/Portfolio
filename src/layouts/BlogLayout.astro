---
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Icon from '@/components/common/Icon.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, heroImage, tags = [] } = Astro.props;
const canonicalPath = Astro.url.pathname;
const siteUrl = Astro.site ?? new URL('https://jpclow.dev');
const articleUrl = new URL(canonicalPath, siteUrl).toString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  image: heroImage ? [new URL(heroImage, siteUrl).toString()] : undefined,
  mainEntityOfPage: articleUrl,
  author: {
    '@type': 'Person',
    name: 'Joao Paulo Goncalves Santos',
    url: siteUrl.toString(),
  },
  keywords: tags,
};

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title={`${title} | João Paulo Santos`}
  description={description}
  ogType="article"
  articlePublishedTime={pubDate.toISOString()}
  articleModifiedTime={(updatedDate ?? pubDate).toISOString()}
  articleTags={tags}
  ogImage={heroImage ?? '/favicon.svg'}
  schema={articleSchema}
>
  <Header />

  <main id="main-content" class="pb-14 pt-[5.5rem]" tabindex="-1">
    <article class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <header class="mb-9">
        <div class="mb-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="rounded px-2.5 py-1 text-xs font-medium bg-[rgb(var(--color-accent)/0.1)] text-[rgb(var(--color-accent))]">
              {tag}
            </span>
          ))}
        </div>

        <h1 class="mb-4 text-3xl font-bold sm:text-4xl">{title}</h1>

        <p class="mb-5 text-base leading-relaxed text-[rgb(var(--color-text-secondary))]">
          {description}
        </p>

        <div class="flex items-center gap-4 text-sm text-[rgb(var(--color-text-muted))]">
          <time datetime={pubDate.toISOString()} class="flex items-center gap-1.5">
            <Icon name="calendar" size={14} />
            {formatDate(pubDate)}
          </time>
          {updatedDate && (
            <>
              <span>•</span>
              <span>Updated: {formatDate(updatedDate)}</span>
            </>
          )}
        </div>
      </header>

      <nav aria-label="Breadcrumb" class="mb-7">
        <ol class="flex items-center gap-2 text-sm text-[rgb(var(--color-text-secondary))]">
          <li>
            <a
              href="/"
              class="rounded-sm hover:text-[rgb(var(--color-accent))] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg-primary))] transition-colors"
            >
              Home
            </a>
          </li>
          <li aria-hidden="true" class="text-[rgb(var(--color-text-muted))]">/</li>
          <li>
            <a
              href="/blog"
              class="rounded-sm hover:text-[rgb(var(--color-accent))] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg-primary))] transition-colors"
            >
              Blog
            </a>
          </li>
          <li aria-hidden="true" class="text-[rgb(var(--color-text-muted))]">/</li>
          <li aria-current="page" class="truncate text-[rgb(var(--color-text-primary))] font-medium">
            {title}
          </li>
        </ol>
      </nav>

      <!-- Hero Image -->
      {heroImage && (
        <div class="mb-9 overflow-hidden rounded-lg border border-[rgb(var(--color-border))] shadow-sm">
          <img
            src={heroImage}
            alt={title}
            class="w-full h-auto"
            loading="lazy"
            decoding="async"
          />
        </div>
      )}

      <!-- Content -->
      <div class="prose prose-slate dark:prose-invert max-w-none">
        <slot />
      </div>

      <!-- Back to blog -->
      <div class="mt-12 border-t border-[rgb(var(--color-border))] pt-7">
        <a
          href="/blog"
          class="group inline-flex items-center gap-2 rounded-md px-3 py-2 text-[rgb(var(--color-accent))] transition-colors hover:bg-[rgb(var(--color-accent)/0.1)] focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg-primary))]"
        >
          <span class="group-hover:-translate-x-1 transition-transform">
            <Icon name="arrow-down" size={16} class="rotate-90" />
          </span>
          Back to all posts
        </a>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>
