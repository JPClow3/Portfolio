+  height: 2px;
+  bottom: -2px;
+  left: 0;
+  background-color: rgb(var(--color-accent));
+  transform-origin: bottom right;
+  transition: transform 0.25s ease-out;
+}
+
+.link-underline:hover::after,
+.link-underline:focus-visible::after {
+  transform: scaleX(1);
+  transform-origin: bottom left;
+}
+
