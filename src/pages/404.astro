---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Icon from '@/components/common/Icon.astro';

const title = '404 - Page Not Found';
const description = 'The page you are looking for does not exist.';
---

<BaseLayout title={title} description={description}>
  <main id="main-content" tabindex="-1" class="flex min-h-screen items-center justify-center px-4 py-20 sm:px-6 lg:px-8">
    <div class="text-center max-w-md w-full">
      <!-- 404 Icon/Illustration -->
      <div class="mb-6">
        <h1 class="bg-gradient-to-r from-[rgb(var(--color-accent))] via-sky-500 to-blue-500 bg-clip-text text-7xl font-extrabold text-transparent sm:text-8xl">
          404
        </h1>
      </div>

      <!-- Error Message -->
      <h2 class="mb-3 text-2xl font-bold text-[rgb(var(--color-text-primary))] sm:text-3xl">
        Page Not Found
      </h2>

      <p class="mb-7 text-base text-[rgb(var(--color-text-secondary))]">
        Sorry, the page you're looking for doesn't exist. Let's get you back on track.
      </p>

      <!-- Action Buttons -->
      <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-md bg-[rgb(var(--color-accent))] px-5 py-2.5 font-semibold text-[rgb(var(--color-accent-contrast))] transition-all duration-200 hover:-translate-y-0.5"
        >
          Back to Home
        </a>

        <a
          href="/blog"
          class="inline-flex items-center gap-2 rounded-md border border-[rgb(var(--color-accent))] px-5 py-2.5 font-semibold text-[rgb(var(--color-accent))] transition-all duration-200 hover:bg-[rgb(var(--color-accent)/0.1)]"
        >
          <Icon name="code" size={20} />
          Blog
        </a>
      </div>

      <!-- Decorative Elements -->
      <div class="mt-12 space-y-3 text-sm text-[rgb(var(--color-text-secondary))]">
        <p>Lost in the digital void? Here are some suggestions:</p>
        <ul class="space-y-2">
          <li>• Check the URL for typos</li>
          <li>• Return to the homepage</li>
          <li>• Browse the blog</li>
        </ul>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  main {
    animation: fade-in 300ms ease-out;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    main {
      animation: none;
    }
  }
</style>
