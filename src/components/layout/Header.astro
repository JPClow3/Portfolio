---
import ThemeToggle from '@components/islands/ThemeToggle.svelte';
import Icon from '@components/common/Icon.astro';
import { defaultLang, type Lang, ui } from '@/lib/i18n';

interface NavLink {
  label: string;
  href: string;
}

const currentLang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = ui[currentLang] ?? ui[defaultLang];

const isEnglish = currentLang === 'en';
const isPortuguese = currentLang === 'pt';

const navLinks: NavLink[] = [
  { label: t['nav.about'], href: '/#about' },
  { label: t['nav.projects'], href: '/#projects' },
  { label: t['nav.experience'], href: '/#experience' },
  { label: t['nav.activity'], href: '/#activity' },
  { label: t['nav.blog'], href: '/blog' },
  { label: t['nav.contact'], href: '/#contact' },
];

// Resume link (separate since it has download behavior)
const resumeLink = isPortuguese ? '/resume-pt.pdf' : '/resume-en.pdf';

---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 glass border-b border-[rgb(var(--color-border)/0.45)] transition-shadow duration-300"
>
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href="/"
        class="text-xl font-bold gradient-text hover:opacity-80 transition-opacity"
      >
        JP<span class="text-[rgb(var(--color-text-secondary))]">.</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link px-4 py-2 text-sm font-medium text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text-primary))] rounded-lg transition-colors relative group focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg-primary))]"
          >
            {link.label}
            <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-[rgb(var(--color-accent))] group-hover:w-4/5 transition-all duration-300" />
          </a>
        ))}
      </div>

      <!-- Right Section -->
      <div class="flex items-center gap-3">
        <a
          href={resumeLink}
          download
          class="hidden md:inline-flex items-center gap-1.5 rounded-full bg-[rgb(var(--color-accent))] px-4 py-2 text-sm font-semibold text-white shadow-[0_10px_30px_rgba(79,70,229,0.35)] transition hover:bg-[rgb(var(--color-accent-hover))]"
          aria-label={`${t['nav.resume']} PDF`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          {t['nav.resume']}
        </a>

        <!-- Language Switcher (Desktop) -->
        <div class="hidden md:flex items-center gap-0.5 rounded-full border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-secondary)/0.5)] p-0.5" role="group" aria-label="Select language">
          <a
            href="/"
            class:list={[
              'px-2.5 py-1 text-xs font-semibold rounded-full transition-colors',
              isEnglish
                ? 'bg-[rgb(var(--color-accent))] text-white'
                : 'text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text-primary))]',
            ]}
            aria-label="Switch to English"
            aria-current={isEnglish ? 'true' : undefined}
          >EN</a>
          <a
            href="/pt/"
            class:list={[
              'px-2.5 py-1 text-xs font-semibold rounded-full transition-colors',
              isPortuguese
                ? 'bg-[rgb(var(--color-accent))] text-white'
                : 'text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text-primary))]',
            ]}
            aria-label="Mudar para Português"
            aria-current={isPortuguese ? 'true' : undefined}
          >PT</a>
        </div>

        <ThemeToggle client:load />

        <!-- Mobile Menu Button -->
        <button
          type="button"
          class="md:hidden p-2 rounded-lg hover:bg-[rgb(var(--color-bg-secondary))] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg-primary))]"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          id="mobile-menu-button"
        >
          <!-- Hamburger icon -->
          <svg
            id="menu-icon-open"
            aria-hidden="true"
            focusable="false"
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4 6h16M4 12h16M4 18h16"
            />
          </svg>
          <!-- Close icon (hidden by default) -->
          <svg
            id="menu-icon-close"
            aria-hidden="true"
            focusable="false"
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6 hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6 18L18 6M6 6l12 12"
            />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div
      id="mobile-menu"
      role="navigation"
      aria-label="Mobile navigation"
      class="md:hidden overflow-hidden transition-all duration-300 ease-in-out rounded-xl bg-[rgb(var(--color-bg-primary))/0.92]"
      style="max-height: 0; opacity: 0;"
    >
      <div class="pb-4 border-t border-[rgb(var(--color-border))] mt-2 pt-4">
        <div class="flex flex-col gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="px-4 py-3 text-sm font-medium text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text-primary))] hover:bg-[rgb(var(--color-bg-secondary))] rounded-lg transition-colors link-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg-primary))]"
            >
              {link.label}
            </a>
          ))}
          <a
            href={resumeLink}
            download
            class="px-4 py-3 text-sm font-medium text-[rgb(var(--color-accent))] hover:bg-[rgb(var(--color-accent)/0.1)] rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg-primary))]"
          >
            {t['nav.resume']}
          </a>

          <!-- Language Switcher (Mobile) -->
          <div class="flex items-center gap-2 px-4 py-3 border-t border-[rgb(var(--color-border))] mt-1 pt-3" role="group" aria-label="Select language">
            <Icon name="globe" size={16} class="text-[rgb(var(--color-text-muted))]" />
            <a
              href="/"
              class:list={[
                'px-3 py-1.5 text-xs font-semibold rounded-full transition-colors',
                isEnglish
                  ? 'bg-[rgb(var(--color-accent))] text-white'
                  : 'text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text-primary))] bg-[rgb(var(--color-bg-secondary))]',
              ]}
              aria-label="Switch to English"
              aria-current={isEnglish ? 'true' : undefined}
            >EN</a>
            <a
              href="/pt/"
              class:list={[
                'px-3 py-1.5 text-xs font-semibold rounded-full transition-colors',
                isPortuguese
                  ? 'bg-[rgb(var(--color-accent))] text-white'
                  : 'text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text-primary))] bg-[rgb(var(--color-bg-secondary))]',
              ]}
              aria-label="Mudar para Português"
              aria-current={isPortuguese ? 'true' : undefined}
            >PT</a>
          </div>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  // Global listener references for cleanup
  let globalEscapeHandler: ((e: KeyboardEvent) => void) | null = null;
  let globalClickHandler: ((e: MouseEvent) => void) | null = null;
  let globalResizeHandler: (() => void) | null = null;

  function initMobileMenu() {
    const menuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    if (!menuButton || !mobileMenu) return;

    const menuButtonEl = menuButton;
    const mobileMenuEl = mobileMenu;

    // Guard against re-initialization
    if (menuButtonEl.dataset.initialized === 'true') return;
    menuButtonEl.dataset.initialized = 'true';

    let isOpen = false;
    let focusTrapActive = false;
    let focusTrapHandler: ((e: KeyboardEvent) => void) | null = null;

    function toggleMenu(open?: boolean) {
      isOpen = open !== undefined ? open : !isOpen;

      // Update aria-expanded
      menuButtonEl.setAttribute('aria-expanded', String(isOpen));

      // Toggle icons
      if (iconOpen && iconClose) {
        iconOpen.classList.toggle('hidden', isOpen);
        iconClose.classList.toggle('hidden', !isOpen);
      }

      // Animate menu
      if (isOpen) {
        mobileMenuEl.style.maxHeight = `${mobileMenuEl.scrollHeight}px`;
        mobileMenuEl.style.opacity = '1';
        focusTrapActive = true;
        attachFocusTrap();

        const firstMenuItem = mobileMenuEl.querySelector('a, button, [tabindex]:not([tabindex="-1"])');
        if (firstMenuItem instanceof HTMLElement) {
          window.requestAnimationFrame(() => firstMenuItem.focus());
        }
      } else {
        mobileMenuEl.style.maxHeight = '0';
        mobileMenuEl.style.opacity = '0';
        focusTrapActive = false;
        detachFocusTrap();
        menuButtonEl.focus();
      }
    }

    function closeMenu() {
      toggleMenu(false);
    }

    function attachFocusTrap() {
      const focusableElements = Array.from(
        mobileMenuEl.querySelectorAll('a, button, [tabindex]:not([tabindex="-1"])')
      ) as HTMLElement[];
      
      if (focusableElements.length === 0) return;

      const firstElement = focusableElements[0];
      const lastElement = focusableElements[focusableElements.length - 1];

      // Remove old handler if it exists
      if (focusTrapHandler) {
        mobileMenuEl.removeEventListener('keydown', focusTrapHandler);
      }

      // Create new handler
      focusTrapHandler = (e: KeyboardEvent) => {
        if (!focusTrapActive || e.key !== 'Tab') return;

        if (e.shiftKey && document.activeElement === firstElement) {
          e.preventDefault();
          lastElement.focus();
        } else if (!e.shiftKey && document.activeElement === lastElement) {
          e.preventDefault();
          firstElement.focus();
        }
      };

      mobileMenuEl.addEventListener('keydown', focusTrapHandler);
    }

    function detachFocusTrap() {
      if (focusTrapHandler) {
        mobileMenuEl.removeEventListener('keydown', focusTrapHandler);
        focusTrapHandler = null;
      }
    }

    // Toggle on button click
    menuButtonEl.addEventListener('click', () => toggleMenu());

    // Close menu when clicking a link
    const links = mobileMenuEl.querySelectorAll('a');
    links.forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Set up global listeners only once
    attachGlobalListeners(closeMenu);
  }

  function attachGlobalListeners(closeMenu: () => void) {
    const menuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    if (!menuButton || !mobileMenu) return;

    // Remove old handlers if they exist (from previous initialization)
    if (globalEscapeHandler) {
      document.removeEventListener('keydown', globalEscapeHandler);
    }
    if (globalClickHandler) {
      document.removeEventListener('click', globalClickHandler);
    }
    if (globalResizeHandler) {
      window.removeEventListener('resize', globalResizeHandler);
    }

    // Create and attach new handlers
    globalEscapeHandler = (e: KeyboardEvent) => {
      const currentIsOpen = menuButton.getAttribute('aria-expanded') === 'true';
      if (e.key === 'Escape' && currentIsOpen) {
        closeMenu();
      }
    };

    globalClickHandler = (e: MouseEvent) => {
      const currentIsOpen = menuButton.getAttribute('aria-expanded') === 'true';
      const target = e.target as Node;
      if (currentIsOpen && !menuButton.contains(target) && !mobileMenu.contains(target)) {
        closeMenu();
      }
    };

    globalResizeHandler = () => {
      const currentIsOpen = menuButton.getAttribute('aria-expanded') === 'true';
      if (window.innerWidth >= 768 && currentIsOpen) {
        closeMenu();
      }
    };

    document.addEventListener('keydown', globalEscapeHandler);
    document.addEventListener('click', globalClickHandler);
    window.addEventListener('resize', globalResizeHandler);
  }

  // Header scroll effect with guard
  function initHeaderScroll() {
    const header = document.getElementById('header');
    if (!header || header.dataset.scrollInitialized === 'true') return;
    const headerEl = header;
    headerEl.dataset.scrollInitialized = 'true';

    function handleScroll() {
      if (window.scrollY > 50) {
        headerEl.classList.add('scrolled');
      } else {
        headerEl.classList.remove('scrolled');
      }
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll(); // Check initial state
  }

  // Initialize on load
  initMobileMenu();
  initHeaderScroll();

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', () => {
    // Only re-initialize header scroll (listeners are already attached globally)
    initHeaderScroll();
  });
</script>

<style>
  #header.scrolled {
    box-shadow: 0 4px 20px rgb(0 0 0 / 0.05);
  }

  :global(html.dark) #header.scrolled {
    box-shadow: 0 4px 20px rgb(0 0 0 / 0.2);
  }

  @media (prefers-reduced-motion: reduce) {
    #header {
      transition: none;
    }
  }
</style>
