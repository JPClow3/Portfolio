---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import ProjectCardEffects from '@/components/islands/ProjectCardEffects.svelte';
import { defaultLang, type Lang, ui } from '@/lib/i18n';
import HeroSection from '@/components/sections/HeroSection.astro';
import ProjectsSection from '@/components/sections/ProjectsSection.astro';
import GithubStatsSection from '@/components/sections/GithubStatsSection.astro';
import ExperienceSection from '@/components/sections/ExperienceSection.astro';
import ActivitySection from '@/components/sections/ActivitySection.astro';
import OptimizationSection from '@/components/sections/OptimizationSection.astro';
import { buildHomeFaqSchema, getHomeSeo } from '@/lib/seo';

const currentLang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = ui[currentLang] ?? ui[defaultLang];
const siteUrl = Astro.site ?? new URL('https://jpclow.dev');
const homeSeo = getHomeSeo(currentLang);

const profileEntries = await getCollection('profile', ({ data }) => data.lang === currentLang);
const fallbackProfileEntries = await getCollection('profile', ({ data }) => data.lang === defaultLang);
const profileEntry = profileEntries[0] ?? fallbackProfileEntries[0];

if (!profileEntry) {
  throw new Error('Profile content entry not found.');
}

const profile = profileEntry.data.profile;

const techMarquee = ['HTML5', 'CSS3', 'JavaScript', 'TypeScript', 'Astro', 'React', 'Tailwind', 'Python'];
const web3FormsAccessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? '';
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY ?? '';
const turnstileWorkerUrl = import.meta.env.PUBLIC_TURNSTILE_WORKER_URL ?? '';
const isContactFormEnabled = Boolean(web3FormsAccessKey);
const isTurnstileEnabled = Boolean(turnstileSiteKey && turnstileWorkerUrl);

async function getLocalizedCollection(collection: 'projects') {
  const localizedEntries = await getCollection(collection, ({ data }) => data.lang === currentLang);

  if (localizedEntries.length > 0 || currentLang === defaultLang) {
    return localizedEntries;
  }

  return getCollection(collection, ({ data }) => data.lang === defaultLang);
}

const projects = (await getLocalizedCollection('projects'))
  .filter((project) => project.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const getProjectUrl = (project: any) =>
  project.data.caseStudy ? `${currentLang === 'pt' ? '/pt' : ''}/projects/${project.data.slug}/` : project.data.link ?? project.data.github ?? '/#projects';

const projectItemsSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: currentLang === 'pt' ? 'Projetos em destaque' : 'Featured Projects',
  itemListElement: projects.map((project, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@type': 'SoftwareSourceCode',
      name: project.data.title,
      description: project.data.description,
      codeRepository: project.data.github,
      url: new URL(getProjectUrl(project), siteUrl).toString(),
      programmingLanguage: project.data.tech,
    },
  })),
};

const homeSchemas = [buildHomeFaqSchema(currentLang), projectItemsSchema];
---

<BaseLayout
  title={homeSeo.title}
  description={homeSeo.description}
  keywords={homeSeo.keywords}
  schema={homeSchemas}
>
  <Header />
  <ProjectCardEffects client:idle />
  <main id="main-content" tabindex="-1" class="noise-bg relative overflow-x-hidden px-4 pb-10 pt-4 sm:px-6 lg:px-8">
    <div class="pointer-events-none fixed inset-0 -z-10">
      <div class="bg-grid absolute inset-0 opacity-45 dark:opacity-20"></div>
    </div>

    <div class="mx-auto max-w-6xl pt-20">
      <HeroSection />

      <OptimizationSection />

      <section aria-label="Technologies" class="marquee-container mb-14 overflow-hidden rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--glass-tint)/var(--glass-bg-opacity))] px-3 py-3">
        <div class="marquee flex min-w-max gap-4 whitespace-nowrap py-1 text-xs font-semibold uppercase tracking-[0.16em] text-[rgb(var(--color-text-secondary))]">
          {[...techMarquee, ...techMarquee].map((tech) => (
            <span class="rounded-md border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-secondary))] px-4 py-1.5">{tech}</span>
          ))}
        </div>
      </section>

      <ProjectsSection />
      
      <GithubStatsSection />

      <ExperienceSection />

      <ActivitySection />

      <section id="contact" data-scene-section="contact" aria-labelledby="contact-heading" class="glass-panel mb-6 rounded-lg p-6">
        <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div class="space-y-5">
            <div>
              <p class="mb-2 text-xs font-bold uppercase tracking-[0.16em] text-[rgb(var(--color-accent))]">{t['home.contactBadge']}</p>
              <h2 id="contact-heading" class="text-3xl font-bold">{t['contact.title']}</h2>
              <p class="mt-3 max-w-xl text-base leading-relaxed text-[rgb(var(--color-text-secondary))]">{t['contact.subtitle']}</p>
            </div>
            <div>
              <a class="block text-lg font-semibold text-[rgb(var(--color-text-primary))] transition-colors hover:text-[rgb(var(--color-accent))]" href={`mailto:${profile.email}`}>{profile.email}</a>
            </div>
            <div class="flex flex-wrap gap-3">
              <a href={`mailto:${profile.email}`} class="hover-lift rounded-md bg-[rgb(var(--color-accent))] px-5 py-2.5 text-sm font-bold text-[rgb(var(--color-accent-contrast))] transition-colors hover:bg-[rgb(var(--color-accent-hover))]">{t['home.sayHello']}</a>
              <a href={profile.linkedin} target="_blank" rel="noreferrer" class="hover-lift rounded-md border border-[rgb(var(--color-border))] bg-[rgb(var(--glass-tint)/0.2)] px-5 py-2.5 text-sm font-bold text-[rgb(var(--color-text-primary))] transition-all hover:border-[rgb(var(--color-border-hover))] hover:bg-[rgb(var(--color-bg-tertiary)/0.5)]">{t['home.linkedin']}</a>
            </div>
          </div>

          {isContactFormEnabled && (
            <form id="contact-form" class="space-y-4 rounded-lg border border-[rgb(var(--color-border)/0.75)] bg-[rgb(var(--color-bg-primary)/0.48)] p-4 text-left shadow-sm md:p-5" novalidate>
              <input type="hidden" name="access_key" value={web3FormsAccessKey} />
              <input type="hidden" name="subject" value="New portfolio contact message" />
              <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

              <div class="space-y-2">
                <label for="name" class="block text-sm font-semibold text-[rgb(var(--color-text-primary))]">{t['contact.form.name']}</label>
                <input id="name" name="name" type="text" autocomplete="name" required aria-describedby="name-error" aria-invalid="false" placeholder={t['contact.form.placeholderName']} class="w-full rounded-md border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-primary))] px-3 py-2.5 text-sm text-[rgb(var(--color-text-primary))] transition-colors placeholder:text-[rgb(var(--color-text-muted))] focus:border-[rgb(var(--color-accent))]" />
                <p id="name-error" class="hidden text-sm text-[rgb(var(--color-error))]"></p>
              </div>

              <div class="space-y-2">
                <label for="email" class="block text-sm font-semibold text-[rgb(var(--color-text-primary))]">{t['contact.form.email']}</label>
                <input id="email" name="email" type="email" autocomplete="email" required aria-describedby="email-error" aria-invalid="false" placeholder={t['contact.form.placeholderEmail']} class="w-full rounded-md border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-primary))] px-3 py-2.5 text-sm text-[rgb(var(--color-text-primary))] transition-colors placeholder:text-[rgb(var(--color-text-muted))] focus:border-[rgb(var(--color-accent))]" />
                <p id="email-error" class="hidden text-sm text-[rgb(var(--color-error))]"></p>
              </div>

              <div class="space-y-2">
                <label for="message" class="block text-sm font-semibold text-[rgb(var(--color-text-primary))]">{t['contact.form.message']}</label>
                <textarea id="message" name="message" rows="5" required minlength="10" aria-describedby="message-error" aria-invalid="false" placeholder={t['contact.form.placeholderMessage']} class="w-full resize-y rounded-md border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-primary))] px-3 py-2.5 text-sm text-[rgb(var(--color-text-primary))] transition-colors placeholder:text-[rgb(var(--color-text-muted))] focus:border-[rgb(var(--color-accent))]"></textarea>
                <p id="message-error" class="hidden text-sm text-[rgb(var(--color-error))]"></p>
              </div>

              {isTurnstileEnabled && (
                <div class="space-y-2">
                  <div
                    class="cf-turnstile min-h-[65px]"
                    data-sitekey={turnstileSiteKey}
                    data-action="turnstile-spin-v1"
                    data-theme="auto"
                  ></div>
                  <p id="turnstile-error" class="hidden text-sm text-[rgb(var(--color-error))]"></p>
                </div>
              )}

              <button id="submit-btn" type="submit" class="inline-flex w-full items-center justify-center rounded-md bg-[rgb(var(--color-accent))] px-5 py-2.5 text-sm font-bold text-[rgb(var(--color-accent-contrast))] transition-colors hover:bg-[rgb(var(--color-accent-hover))] disabled:cursor-not-allowed disabled:opacity-65 sm:w-auto">
                {t['contact.form.send']}
              </button>

              <div id="form-status" aria-live="polite" aria-atomic="true" class="min-h-6 text-sm">
                <p id="success-message" class="hidden font-medium text-emerald-700 dark:text-emerald-300">{t['contact.success']}</p>
                <p id="error-message" class="hidden font-medium text-[rgb(var(--color-error))]">{t['contact.error']}</p>
              </div>
            </form>
          )}
        </div>
      </section>
    </div>
  </main>

  {isTurnstileEnabled && (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  )}

  {isContactFormEnabled && (
    <script
      define:vars={{
        isTurnstileEnabled,
        turnstileWorkerUrl,
        messages: {
          sending: t['contact.form.sending'],
          send: t['contact.form.send'],
          success: t['contact.success'],
          error: t['contact.error'],
          network: t['contact.error.network'],
          validationFix: t['contact.validation.fix'],
          nameRequired: t['contact.validation.nameRequired'],
          emailRequired: t['contact.validation.emailRequired'],
          emailInvalid: t['contact.validation.emailInvalid'],
          messageRequired: t['contact.validation.messageRequired'],
          messageMin: t['contact.validation.messageMin'],
          turnstileRequired: t['contact.turnstile.required'],
          turnstileFailed: t['contact.turnstile.failed'],
        },
      }}
      is:inline
    >
      (() => {
        const form = document.getElementById('contact-form');
        if (!form) return;

        const submitButton = document.getElementById('submit-btn');
        const successMessage = document.getElementById('success-message');
        const errorMessage = document.getElementById('error-message');
        const turnstileError = document.getElementById('turnstile-error');

        const fields = {
          name: document.getElementById('name'),
          email: document.getElementById('email'),
          message: document.getElementById('message'),
        };

        const setError = (field, message) => {
          const error = document.getElementById(`${field.id}-error`);
          field.setAttribute('aria-invalid', message ? 'true' : 'false');
          if (!error) return;
          error.textContent = message || '';
          error.hidden = !message;
          error.classList.toggle('hidden', !message);
        };

        const setTurnstileError = (message) => {
          if (!turnstileError) return;
          turnstileError.textContent = message || '';
          turnstileError.hidden = !message;
          turnstileError.classList.toggle('hidden', !message);
        };

        const setStatus = (type, message) => {
          if (successMessage) {
            successMessage.hidden = type !== 'success';
            successMessage.classList.toggle('hidden', type !== 'success');
            if (type === 'success') successMessage.textContent = message;
          }

          if (errorMessage) {
            errorMessage.hidden = type !== 'error';
            errorMessage.classList.toggle('hidden', type !== 'error');
            if (type === 'error') errorMessage.textContent = message;
          }
        };

        const resetTurnstile = () => {
          if (window.turnstile?.reset) {
            window.turnstile.reset();
          }
        };

        const validateField = (field) => {
          const value = field.value.trim();

          if (field === fields.name && !value) {
            setError(field, messages.nameRequired);
            return false;
          }

          if (field === fields.email) {
            if (!value) {
              setError(field, messages.emailRequired);
              return false;
            }

            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) {
              setError(field, messages.emailInvalid);
              return false;
            }
          }

          if (field === fields.message) {
            if (!value) {
              setError(field, messages.messageRequired);
              return false;
            }

            if (value.length < 10) {
              setError(field, messages.messageMin);
              return false;
            }
          }

          setError(field, '');
          return true;
        };

        const validateForm = () => {
          const results = Object.values(fields).map((field) => validateField(field));
          return results.every(Boolean);
        };

        Object.values(fields).forEach((field) => {
          field.addEventListener('blur', () => validateField(field));
          field.addEventListener('input', () => {
            if (field.getAttribute('aria-invalid') === 'true') {
              validateField(field);
            }
          });
        });

        const verifyTurnstile = async () => {
          if (!isTurnstileEnabled) return true;

          const token = new FormData(form).get('cf-turnstile-response');
          if (!token) {
            setTurnstileError(messages.turnstileRequired);
            setStatus('error', messages.turnstileRequired);
            return false;
          }

          const response = await fetch(turnstileWorkerUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ token }),
          });

          const data = await response.json().catch(() => null);
          if (!response.ok || !data?.success) {
            setTurnstileError(messages.turnstileFailed);
            setStatus('error', messages.turnstileFailed);
            resetTurnstile();
            return false;
          }

          setTurnstileError('');
          return true;
        };

        form.addEventListener('submit', async (event) => {
          event.preventDefault();
          setStatus('', '');
          setTurnstileError('');

          if (!validateForm()) {
            setStatus('error', messages.validationFix);
            return;
          }

          submitButton.disabled = true;
          submitButton.textContent = messages.sending;

          try {
            const isVerified = await verifyTurnstile();
            if (!isVerified) return;

            const response = await fetch('https://api.web3forms.com/submit', {
              method: 'POST',
              body: new FormData(form),
            });

            const data = await response.json().catch(() => null);
            if (response.ok && data?.success) {
              form.reset();
              setStatus('success', messages.success);
              resetTurnstile();
              return;
            }

            setStatus('error', messages.error);
          } catch {
            setStatus('error', messages.network);
          } finally {
            submitButton.disabled = false;
            submitButton.textContent = messages.send;
          }
        });
      })();
    </script>
  )}

  <Footer />
</BaseLayout>
