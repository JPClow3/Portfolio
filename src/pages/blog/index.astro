---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { ui } from '@/lib/i18n';

const t = ui.en;

const posts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const siteUrl = Astro.site ?? new URL('https://jpclow.dev');
const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Joao Paulo Santos Blog',
  description: t['blog.subtitle'],
  url: new URL('/blog', siteUrl).toString(),
  blogPost: sortedPosts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
    url: new URL(`/blog/${post.id}`, siteUrl).toString(),
  })),
};

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Blog | João Paulo Santos"
  description="Thoughts on software development, front-end technologies, and my learning journey."
  ogImage="/favicon.svg"
  schema={blogSchema}
>
  <Header />

  <main id="main-content" class="pb-14 pt-[5.5rem]" tabindex="-1">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-10 text-center">
        <h1 class="mb-3 text-3xl font-bold sm:text-4xl">{t['blog.title']}</h1>
        <p class="text-base text-[rgb(var(--color-text-muted))]">
          Thoughts on software development, front-end technologies, and my learning journey.
        </p>
      </div>

      <!-- Posts -->
      {sortedPosts.length > 0 ? (
        <div class="space-y-4">
          {sortedPosts.map((post) => (
            <article class="glass-panel group rounded-lg p-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-[rgb(var(--color-accent)/0.5)]">
              <a href={`/blog/${post.id}`} class="block">
                <div class="mb-3 flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="rounded px-2 py-0.5 text-xs font-medium text-[rgb(var(--color-text-muted))] bg-[rgb(var(--color-bg-tertiary))]">
                      {tag}
                    </span>
                  ))}
                </div>

                <h2 class="mb-2 text-xl font-semibold transition-colors group-hover:text-[rgb(var(--color-accent))]">
                  {post.data.title}
                </h2>

                <p class="mb-4 line-clamp-2 text-[rgb(var(--color-text-secondary))]">
                  {post.data.description}
                </p>

                <div class="flex items-center justify-between">
                  <time
                    datetime={post.data.pubDate.toISOString()}
                    class="text-sm text-[rgb(var(--color-text-muted))]"
                  >
                    {formatDate(post.data.pubDate)}
                  </time>

                  <span class="text-sm font-medium text-[rgb(var(--color-accent))] group-hover:underline">
                    {t['blog.readMore']} →
                  </span>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="py-14 text-center">
          <p class="text-[rgb(var(--color-text-muted))]">
            No posts yet. Check back soon!
          </p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>
