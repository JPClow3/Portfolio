---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Icon from '@/components/common/Icon.astro';

const title = '404 - Page Not Found';
const description = 'The page you are looking for does not exist.';
---

<BaseLayout title={title} description={description} noindex>
  <Header />

  <main id="main-content" tabindex="-1" class="flex min-h-[80vh] items-center justify-center px-4 py-12 pt-[6.5rem] sm:px-6 lg:px-8 animate-fade-in">
    <div class="w-full max-w-md text-center">
      <!-- 404 Icon/Illustration -->
      <div class="mb-6">
        <h1 class="gradient-text text-7xl font-extrabold sm:text-8xl">
          404
        </h1>
      </div>

      <!-- Error Message -->
      <h2 class="mb-3 text-2xl font-bold text-[rgb(var(--color-text-primary))] sm:text-3xl">
        Page Not Found
      </h2>

      <p class="mb-7 text-base text-[rgb(var(--color-text-secondary))]">
        Sorry, the page you're looking for doesn't exist. Let's get you back on track.
      </p>

      <!-- Action Buttons -->
      <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href="/"
          class="hover-lift inline-flex items-center gap-2 rounded-md bg-[rgb(var(--color-accent))] px-5 py-2.5 font-semibold text-[rgb(var(--color-accent-contrast))] transition-colors hover:bg-[rgb(var(--color-accent-hover))]"
        >
          Back to Home
        </a>

        <a
          href="/blog"
          class="inline-flex items-center gap-2 rounded-md border border-[rgb(var(--color-border))] bg-[rgb(var(--glass-tint)/0.28)] px-5 py-2.5 font-semibold text-[rgb(var(--color-text-primary))] transition-all hover:border-[rgb(var(--color-border-hover))] hover:bg-[rgb(var(--color-bg-tertiary)/0.55)]"
        >
          <Icon name="code" size={20} />
          Blog
        </a>
      </div>

      <!-- Decorative Elements -->
      <div class="mt-12 space-y-3 text-sm text-[rgb(var(--color-text-secondary))]">
        <p>Lost in the digital void? Here are some suggestions:</p>
        <ul class="space-y-2">
          <li>• Check the URL for typos</li>
          <li>• Return to the homepage</li>
          <li>• Browse the blog</li>
        </ul>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
