---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import { defaultLang, type Lang, ui } from '@/lib/i18n';
import { getGithubActivity, type EventType } from '@/lib/github';

const currentLang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = ui[currentLang] ?? ui[defaultLang];

const profileEntries = await getCollection('profile', ({ data }) => data.lang === currentLang);
const fallbackProfileEntries = await getCollection('profile', ({ data }) => data.lang === defaultLang);
const profileEntry = profileEntries[0] ?? fallbackProfileEntries[0];

if (!profileEntry) {
  throw new Error('Profile content entry not found.');
}

const profile = profileEntry.data.profile;

const currentFocus = profileEntry.data.currentFocus;

const techMarquee = ['HTML5', 'CSS3', 'JavaScript', 'TypeScript', 'Astro', 'React', 'Tailwind', 'Python'];

async function getLocalizedCollection<C extends 'projects' | 'experience'>(collection: C): Promise<CollectionEntry<C>[]> {
  const localizedEntries = await getCollection(collection, ({ data }) => data.lang === currentLang);

  if (localizedEntries.length > 0 || currentLang === defaultLang) {
    return localizedEntries;
  }

  return getCollection(collection, ({ data }) => data.lang === defaultLang);
}

const projects = (await getLocalizedCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const experience = (await getLocalizedCollection('experience'))
  .sort((a, b) => a.data.order - b.data.order);

const recentGithubActivity = await getGithubActivity(
  profileEntry.data.customMetric.githubUsername,
  profileEntry.data.customMetric.fallbackEvents,
);

/** Returns intensity levels 0–4 for a heatmap strip (10 squares) from repo+date. */
function getActivityHeatmapLevels(repo: string, date: string): number[] {
  const seed = `${repo}-${date}`;
  const levels: number[] = [];
  for (let i = 0; i < 10; i++) {
    const hash = seed.split('').reduce((acc, c) => acc + c.charCodeAt(0) + i, 0);
    levels.push(hash % 5);
  }
  return levels;
}

const EVENT_BADGE_LABELS_BY_LANG: Record<Lang, Record<EventType, string>> = {
  en: { push: 'Push', pr: 'PR', create: 'Create' },
  pt: { push: 'Commit', pr: 'PR', create: 'Criação' },
};

const EVENT_BADGE_LABELS = EVENT_BADGE_LABELS_BY_LANG[currentLang] ?? EVENT_BADGE_LABELS_BY_LANG[defaultLang];

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat(currentLang === 'pt' ? 'pt-BR' : 'en-US', {
    month: 'short',
    year: 'numeric',
  }).format(date);
---

<BaseLayout title="João Paulo Gonçalves Santos - Portfolio" description="Personal portfolio of João Paulo with projects, journey and GitHub updates.">
  <Header />
  <main id="main-content" tabindex="-1" class="noise-bg relative overflow-x-hidden px-4 pb-14 pt-6 sm:px-6 lg:px-8">
    <div class="pointer-events-none fixed inset-0 -z-10">
      <div class="bg-grid absolute inset-0 opacity-10"></div>
      <div class="absolute -right-24 -top-24 h-[420px] w-[420px] rounded-full bg-violet-600/20 blur-[120px]"></div>
      <div class="absolute -left-24 top-[42%] h-[360px] w-[360px] rounded-full bg-indigo-500/20 blur-[120px]"></div>
    </div>

    <div class="mx-auto max-w-7xl pt-24">
      <header id="about" class="mb-24 grid grid-cols-1 items-start gap-10 lg:grid-cols-12">
        <div class="lg:col-span-7">
          <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-[rgb(var(--primary))/0.25] bg-[rgb(var(--primary))/0.1] px-3 py-1 text-xs font-semibold uppercase tracking-wide text-[rgb(var(--primary))]">
            <span class="relative flex h-2.5 w-2.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-70"></span>
              <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
            </span>
            {t['home.availability']}
          </div>

          <h1 class="max-w-3xl text-5xl font-extrabold leading-[1.02] tracking-tight text-slate-100 md:text-6xl lg:text-7xl">
            I’m João — crafting
            <span class="text-gradient block">beautiful, reliable</span>
            digital experiences.
          </h1>

          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-300/80">{profile.subtitle}</p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#projects" class="rounded-full bg-white px-7 py-3 text-sm font-semibold text-slate-900 transition hover:-translate-y-0.5 hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/80 focus-visible:ring-offset-2 focus-visible:ring-offset-[#110d24]">{t['home.viewWork']}</a>
            <a href={profile.github} target="_blank" rel="noreferrer" class="rounded-full border border-white/20 px-7 py-3 text-sm font-semibold text-white/90 transition hover:border-white/40 hover:bg-white/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--primary))] focus-visible:ring-offset-2 focus-visible:ring-offset-[#110d24]">{t['home.githubProfile']}</a>
          </div>
        </div>

        <div class="flex flex-col gap-5 lg:col-span-5">
          <article class="glass-panel rounded-3xl p-7 text-center">
            <div class="mx-auto mb-3 flex h-24 w-24 items-center justify-center overflow-hidden rounded-full border-2 border-[rgb(var(--primary))/0.55] shadow-[0_0_30px_rgb(79,70,229,0.3)]">
              <img
                src={`https://2.gravatar.com/avatar/${profile.gravatarHash}?s=180&d=initials`}
                alt={profile.shortName}
                width="90"
                height="90"
                loading="lazy"
                class="hovercard h-full w-full object-cover"
              />
            </div>
            <h2 class="text-2xl font-bold">{profile.shortName}</h2>
            <p class="text-sm font-medium text-[rgb(var(--primary))]">{profile.role}</p>
            <div class="mt-3 flex justify-center gap-2 text-xs">
              <span class="rounded-full border border-white/15 bg-white/5 px-3 py-1">🇧🇷 {profile.location}</span>
              <span class="rounded-full border border-white/15 bg-white/5 px-3 py-1">{profile.timezone}</span>
            </div>
            <div class="mt-6 grid grid-cols-3 gap-2 border-t border-white/10 pt-5 text-center">
              <div><p class="text-lg font-bold">3+</p><p class="text-[10px] uppercase text-slate-400">{t['home.years']}</p></div>
              <div><p class="text-lg font-bold">20+</p><p class="text-[10px] uppercase text-slate-400">{t['home.projects']}</p></div>
              <div><p class="text-lg font-bold">100%</p><p class="text-[10px] uppercase text-slate-400">{t['home.commitment']}</p></div>
            </div>
          </article>

          <article class="glass-panel rounded-3xl p-6">
            <p class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-slate-400">{currentFocus.title}</p>
            <div class="space-y-4">
              {currentFocus.items.map((item) => (
                <div class="flex items-start gap-3">
                  <span class="material-symbols-outlined rounded-xl bg-white/10 p-2 text-base text-[rgb(var(--primary))]">{item.icon}</span>
                  <div>
                    <p class="text-[10px] uppercase tracking-[0.18em] text-slate-400">{item.label}</p>
                    <p class="text-sm text-slate-100">{item.value}</p>
                  </div>
                </div>
              ))}
            </div>
          </article>
        </div>
      </header>

      <section class="mb-24 overflow-hidden rounded-2xl border border-white/10 bg-white/5 px-4 py-8">
        <h3 class="mb-4 text-center text-xs font-bold uppercase tracking-[0.25em] text-slate-400">{t['home.technologies']}</h3>
        <div class="marquee flex min-w-max gap-6 whitespace-nowrap py-2 text-sm font-semibold uppercase tracking-[0.16em] text-slate-300/80">
          {[...techMarquee, ...techMarquee].map((tech) => (
            <span class="rounded-full border border-white/15 bg-[#0f1122] px-5 py-2">{tech}</span>
          ))}
        </div>
      </section>

      <section id="projects" class="mb-24">
        <div class="mb-8 flex items-end justify-between">
          <h2 class="text-4xl font-bold tracking-tight">{t['home.buildTitle']}</h2>
          <a href={`${profile.github}?tab=repositories`} target="_blank" rel="noreferrer" class="text-sm text-slate-400 transition-colors hover:text-white">{t['home.seeAllRepos']}</a>
        </div>

        <div class="bento-grid">
          {projects.map((project, index) => (
            <article class:list={[
              'group glass-panel relative overflow-hidden rounded-3xl p-6 transition-all hover:-translate-y-1 hover:border-[rgb(var(--primary))]/40',
              index === 0 ? 'bento-span-2' : '',
              index === 1 ? 'bento-row-span-2' : '',
            ]}>
              <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/10 via-transparent to-purple-500/10 opacity-80 transition-opacity group-hover:opacity-100"></div>
              <div class="relative">
                <h3 class="text-2xl font-bold">{project.data.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-slate-300/80">{project.data.description}</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {project.data.tech.slice(0, 4).map((tech) => (
                    <span class="rounded-full border border-white/20 bg-[#10142c] px-3 py-1 text-[10px] uppercase tracking-wide text-slate-300">{tech}</span>
                  ))}
                </div>
                <div class="mt-5 flex gap-4 text-sm">
                  {project.data.github && <a href={project.data.github} target="_blank" rel="noreferrer" class="font-semibold text-[rgb(var(--primary))] hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--primary))] focus-visible:ring-offset-2 focus-visible:ring-offset-[#110d24]">{t['home.viewProject']}</a>}
                  {project.data.link && <a href={project.data.link} target="_blank" rel="noreferrer" class="text-slate-300 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--primary))] focus-visible:ring-offset-2 focus-visible:ring-offset-[#110d24]">{t['home.live']}</a>}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="experience" class="mb-24">
        <h2 class="mb-10 text-4xl font-bold tracking-tight">{t['home.journeyTitle']}</h2>
        <div class="timeline relative space-y-6 pl-8">
          {experience.map((job, idx) => (
            <article class="glass-panel relative rounded-2xl p-6 transition hover:border-[rgb(var(--primary))]/35">
              <span class:list={[
                'absolute -left-[31px] top-7 h-5 w-5 rounded-full border-4 border-[#120f23] shadow-[0_0_0_2px_rgba(255,255,255,0.06)]',
                idx === 0 ? 'bg-[rgb(var(--primary))]' : 'bg-slate-500',
              ]}></span>
              <div class="mb-3 flex flex-col justify-between gap-2 sm:flex-row sm:items-center">
                <div>
                  <h3 class="text-xl font-bold">{job.data.role}</h3>
                  <p class="text-[rgb(var(--primary))]">{job.data.company}</p>
                </div>
                <span class="rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs text-slate-300">{formatDate(job.data.startDate)} — {job.data.endDate ? formatDate(job.data.endDate) : t['home.present']}</span>
              </div>
              <ul class="list-disc space-y-1 pl-5 text-sm text-slate-300/80 marker:text-[rgb(var(--primary))]">
                {job.data.tasks.slice(0, 2).map((task) => (
                  <li>{task}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section id="activity" class="mb-20">
        <div class="mb-6 flex items-end justify-between">
          <h2 class="text-3xl font-bold">{t['home.latestActivity']}</h2>
          <a href={profile.github} target="_blank" rel="noreferrer" class="text-sm text-slate-400 transition-colors hover:text-[rgb(var(--primary))]">{t['home.viewFullProfile']}</a>
        </div>
        <div class="space-y-4">
          {recentGithubActivity.map((event) => {
            const heatLevels = getActivityHeatmapLevels(event.repo, event.date);
            const eventType = event.eventType ?? 'push';
            return (
              <a
                href={event.url}
                target="_blank"
                rel="noreferrer"
                class="activity-card group glass-panel block overflow-hidden rounded-2xl border-white/20 transition-all hover:border-[rgb(var(--primary))]/40"
              >
                <div class="flex items-center justify-between border-b border-white/10 bg-white/5 px-4 py-3">
                  <div class="flex items-center gap-3">
                    <span class="text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--primary))]">{event.repo}</span>
                    <span class={`rounded px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider ${eventType === 'push' ? 'bg-purple-900/80 text-violet-300' : eventType === 'pr' ? 'bg-purple-700/80 text-violet-200' : 'bg-purple-500/80 text-white'}`}>
                      {EVENT_BADGE_LABELS[eventType]}
                    </span>
                  </div>
                  <span class="text-xs text-slate-400">{event.date}</span>
                </div>
                <div class="p-4">
                  <p class="text-sm leading-relaxed text-slate-200/90">{event.message}</p>
                  <div class="mt-3 flex gap-1">
                    {heatLevels.map((level, i) => (
                      <span key={i} class={`h-3 w-3 shrink-0 rounded-sm activity-heat-${level}`} aria-hidden />
                    ))}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>

      <footer id="contact" class="glass-panel mb-8 flex flex-col items-center justify-between gap-6 rounded-3xl p-10 text-center md:flex-row md:text-left">
        <div>
          <p class="mb-2 inline-block rounded-full border border-[rgb(var(--primary))]/40 bg-[rgb(var(--primary))]/20 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--primary))]">{t['home.contactBadge']}</p>
          <h2 class="text-4xl font-bold">{t['home.contactTitle']}</h2>
          <a class="mt-2 block text-xl text-slate-300 transition-colors hover:text-white" href={`mailto:${profile.email}`}>{profile.email}</a>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href={`mailto:${profile.email}`} class="rounded-full bg-[rgb(var(--primary))] px-7 py-3 text-sm font-bold text-white transition hover:bg-[rgb(var(--color-accent-hover))]">{t['home.sayHello']}</a>
          <a href={profile.linkedin} target="_blank" rel="noreferrer" class="rounded-full border border-white/15 px-7 py-3 text-sm font-bold text-slate-100 transition hover:border-white/35 hover:bg-white/5">{t['home.linkedin']}</a>
        </div>
      </footer>
    </div>
  </main>
</BaseLayout>
